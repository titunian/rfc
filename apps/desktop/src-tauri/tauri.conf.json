{
  "$schema": "https://raw.githubusercontent.com/nicedoc/tauri/main/core/tauri/src/schema.json",
  "productName": "orfc",
  "version": "0.1.0",
  "identifier": "dev.orfc.desktop",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1420",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "orfc",
        "width": 1180,
        "height": 800,
        "minWidth": 720,
        "minHeight": 480,
        "decorations": true,
        "transparent": false,
        "titleBarStyle": "Overlay",
        "hiddenTitle": true,
        "trafficLightPosition": {
          "x": 16,
          "y": 16
        }
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "fileAssociations": [
      {
        "ext": ["md", "markdown"],
        "name": "Markdown Document",
        "description": "Markdown text document",
        "role": "Editor",
        "mimeType": "text/markdown"
      }
    ],
    "macOS": {
      "minimumSystemVersion": "10.15"
    }
  }
}
