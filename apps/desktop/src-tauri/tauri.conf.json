{
  "$schema": "https://raw.githubusercontent.com/nicedoc/tauri/main/core/tauri/src/schema.json",
  "productName": "orfc",
  "version": "0.1.0",
  "identifier": "dev.orfc.desktop",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1420",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "title": "orfc",
    "windows": [
      {
        "title": "orfc",
        "width": 1100,
        "height": 750,
        "minWidth": 600,
        "minHeight": 400,
        "decorations": true,
        "transparent": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "plugins": {
    "fs": {
      "scope": {
        "allow": ["**"]
      }
    },
    "dialog": {
      "all": true
    },
    "shell": {
      "open": true
    }
  }
}
