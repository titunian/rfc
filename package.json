{
  "name": "orfc",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "turbo dev",
    "build": "turbo build",
    "lint": "turbo lint",
    "test": "turbo test",
    "db:push": "cd apps/web && npx drizzle-kit push",
    "db:generate": "cd apps/web && npx drizzle-kit generate",
    "db:migrate": "cd apps/web && npx drizzle-kit migrate"
  },
  "devDependencies": {
    "turbo": "^2.3.0"
  },
  "packageManager": "npm@10.0.0"
}
